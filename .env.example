# OCI Core
OCI_REGION=us-chicago-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxx
OCI_TENANCY_ID=ocid1.tenancy.oc1..xxxxxxxxxx

# OCI GenAI (Cohere Command R+)
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/20231130
OCI_GENAI_MODEL_ID=cohere.command-r-plus
OCI_GENAI_API_KEY=your_api_key_here

# ADB 26ai
ADB_DSN=proviso_high
ADB_USER=WORKBENCH_USER
ADB_PASSWORD=your_password_here
ADB_WALLET_DIR=/opt/oracle/wallet

# App
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*
